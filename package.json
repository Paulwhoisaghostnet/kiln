{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "pretest": "bash scripts/ensure-token-artifacts.sh",
    "dev": "tsx server.ts",
    "start": "cross-env NODE_ENV=production node dist/server.cjs",
    "start:dev": "cross-env NODE_ENV=production tsx server.ts",
    "build:client": "vite build",
    "build:server": "esbuild server.ts --bundle --platform=node --format=cjs --target=node22 --outfile=dist/server.cjs --packages=external --loader:.ts=ts",
    "build": "npm run build:client && npm run build:server",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:shadownet": "vitest run tests/shadownet.smoke.test.ts",
    "compile:tokens": "bash scripts/compile-token-contracts.sh",
    "compile:wtf": "bash scripts/wtf/compile-wtf-contracts.sh",
    "deploy:dummy-tokens": "tsx scripts/deploy-dummy-tokens.ts",
    "kiln:cli": "tsx scripts/kiln-cli.ts",
    "wtf:check-templates": "tsx scripts/wtf/run-template-checks.ts",
    "netlify:dev": "npx netlify dev",
    "netlify:deploy:preview": "npx netlify deploy",
    "netlify:deploy:prod": "npx netlify deploy --prod",
    "check": "npm run lint && npm run test && npm run build"
  },
  "dependencies": {
    "@airgap/beacon-dapp": "^4.8.1",
    "@taquito/beacon-wallet": "^24.2.0",
    "@taquito/signer": "^24.2.0",
    "@taquito/taquito": "^24.2.0",
    "buffer": "^6.0.3",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.1.0",
    "helmet": "^8.1.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "serverless-http": "^4.0.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@netlify/functions": "^5.2.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/supertest": "^6.0.3",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.4.21",
    "cross-env": "^10.1.0",
    "daisyui": "^5.5.19",
    "esbuild": "^0.25.0",
    "supertest": "^7.1.4",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vite-plugin-node-polyfills": "^0.26.0",
    "vitest": "^3.2.4"
  }
}
