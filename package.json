{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "pretest": "bash scripts/ensure-token-artifacts.sh",
    "dev": "tsx server.ts",
    "start": "cross-env NODE_ENV=production node dist/server.cjs",
    "start:dev": "cross-env NODE_ENV=production tsx server.ts",
    "build:client": "vite build",
    "build:server": "esbuild server.ts --bundle --platform=node --format=cjs --target=node22 --outfile=dist/server.cjs --packages=external --loader:.ts=ts",
    "build": "npm run build:client && npm run build:server",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:shadownet": "vitest run tests/shadownet.smoke.test.ts",
    "compile:tokens": "bash scripts/compile-token-contracts.sh",
    "compile:wtf": "bash scripts/wtf/compile-wtf-contracts.sh",
    "deploy:dummy-tokens": "tsx scripts/deploy-dummy-tokens.ts",
    "kiln:cli": "tsx scripts/kiln-cli.ts",
    "wtf:check-templates": "tsx scripts/wtf/run-template-checks.ts",
    "marketplace:suite": "tsx scripts/run-fa2-marketplace-suite.ts",
    "e2e": "playwright test",
    "e2e:live": "cross-env KILN_E2E_MODE=passive-live playwright test tests/e2e",
    "e2e:auth": "cross-env KILN_E2E_MODE=auth-live playwright test tests/e2e/00-live-api-contract.spec.ts tests/e2e/02-a11y.spec.ts tests/e2e/03-method-and-guardrails.spec.ts",
    "e2e:report": "node scripts/e2e/generate-kiln-report.mjs",
    "e2e:report:audit": "node scripts/e2e/audit-kiln-report.mjs",
    "e2e:lighthouse": "node scripts/e2e/run-lighthouse.mjs",
    "e2e:all": "node scripts/e2e/run-kiln-live-suite.mjs",
    "check": "npm run lint && npm run test && npm run build"
  },
  "dependencies": {
    "@airgap/beacon-dapp": "^4.8.1",
    "@stablelib/blake2b": "^1.0.1",
    "@taquito/beacon-wallet": "^24.3.0",
    "@taquito/signer": "^24.3.0",
    "@taquito/taquito": "^24.3.0",
    "buffer": "^6.0.3",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.1.0",
    "helmet": "^8.1.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "solc": "^0.8.34",
    "tailwind-merge": "^3.5.0",
    "viem": "^2.48.4",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@playwright/test": "^1.54.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/supertest": "^6.0.3",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.4.21",
    "axe-core": "^4.11.2",
    "cross-env": "^10.1.0",
    "daisyui": "^5.5.19",
    "esbuild": "^0.25.0",
    "lighthouse": "^12.8.2",
    "supertest": "^7.1.4",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vite-plugin-node-polyfills": "^0.26.0",
    "vitest": "^3.2.4",
    "wait-on": "^8.0.0"
  }
}
