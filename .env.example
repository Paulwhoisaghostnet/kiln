NODE_ENV=development
PORT=3000

# Tezos network configuration
TEZOS_RPC_URL=https://rpc.shadownet.teztnets.com
TEZOS_CHAIN_ID=

# Wallet secret keys used by server-side signer flows
WALLET_A_SECRET_KEY=
WALLET_B_SECRET_KEY=

# Comma-separated KT1 addresses used by injector replacement
KILN_DUMMY_TOKENS=KT1VsSxSXUkgw6zkBGgUuDXXuJs9ToPqkrCg,KT1HbQepzV1nVGg8QVznG7z4RcHseD5kwqBn

# Optional API protection
API_AUTH_TOKEN=
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=30
API_JSON_LIMIT=10mb

# Optional comma-separated allowlist for browser origins
CORS_ORIGINS=http://localhost:3000
