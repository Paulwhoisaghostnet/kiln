NODE_ENV=development
PORT=3000

# Tezos network configuration
TEZOS_RPC_URL=https://rpc.shadownet.teztnets.com
TEZOS_CHAIN_ID=

# Wallet secret keys used by server-side signer flows
WALLET_A_SECRET_KEY=
WALLET_B_SECRET_KEY=

# Token contract addresses (bronze -> diamond)
KILN_DUMMY_TOKENS=
KILN_TOKEN_BRONZE=
KILN_TOKEN_SILVER=
KILN_TOKEN_GOLD=
KILN_TOKEN_PLATINUM=
KILN_TOKEN_DIAMOND=

# Optional API protection
API_AUTH_TOKEN=
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=30
API_JSON_LIMIT=10mb

# Optional CORS allowlist (comma-separated)
# Leave empty in production when frontend and API share the same Netlify domain.
# Supports wildcard previews, for example: https://*.netlify.app
CORS_ORIGINS=
