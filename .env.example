NODE_ENV=development
PORT=3000

# Tezos network configuration
KILN_NETWORK=tezos-shadownet
TEZOS_RPC_URL=https://rpc.shadownet.teztnets.com
TEZOS_CHAIN_ID=
ETHERLINK_SHADOWNET_RPC_URL=https://node.shadownet.etherlink.com
ETHERLINK_MAINNET_RPC_URL=https://node.mainnet.etherlink.com

# Wallet secret keys used by server-side signer flows
WALLET_A_SECRET_KEY=
WALLET_B_SECRET_KEY=

# Token contract addresses (bronze -> diamond)
KILN_DUMMY_TOKENS=
KILN_TOKEN_BRONZE=
KILN_TOKEN_SILVER=
KILN_TOKEN_GOLD=
KILN_TOKEN_PLATINUM=
KILN_TOKEN_DIAMOND=

# Optional API protection (server). If set, browser must send the same value:
VITE_API_TOKEN=
API_AUTH_TOKEN=
# Set false to run Kiln as an open public builder while keeping API_AUTH_TOKEN
# configured for fast rollback. Set true to force token auth and fail closed if
# API_AUTH_TOKEN is missing. Leave blank for legacy behavior: auth is required
# only when API_AUTH_TOKEN is set.
KILN_API_AUTH_REQUIRED=
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=30
API_JSON_LIMIT=10mb
KILN_REQUIRE_SIM_CLEARANCE=true

# Shadowbox runtime gate (ephemeral pre-shadownet sandbox execution)
# Enable + set command in Hetzner production to run a real temporary Tezos runtime.
KILN_SHADOWBOX_ENABLED=false
KILN_SHADOWBOX_REQUIRED_FOR_CLEARANCE=false
KILN_SHADOWBOX_PROVIDER=mock
KILN_SHADOWBOX_COMMAND=
# Example real-runtime command on Hetzner:
# KILN_SHADOWBOX_COMMAND=bash /opt/platform/repos/shadownet-kiln/scripts/shadowbox/run-flextesa.sh
KILN_SHADOWBOX_TIMEOUT_MS=90000
KILN_SHADOWBOX_MAX_ACTIVE=2
KILN_SHADOWBOX_MAX_ACTIVE_PER_IP=1
KILN_SHADOWBOX_MAX_SOURCE_BYTES=250000
KILN_SHADOWBOX_MAX_STEPS=80
KILN_SHADOWBOX_WORKDIR=
# Flextesa command-provider defaults (used by scripts/shadowbox/run-flextesa.sh)
KILN_SHADOWBOX_FLEXTESA_IMAGE=oxheadalpha/flextesa:latest
KILN_SHADOWBOX_FLEXTESA_BOX_SCRIPT=nairobibox
KILN_SHADOWBOX_FLEXTESA_BLOCK_TIME=2
KILN_SHADOWBOX_FLEXTESA_RPC_WAIT_SECONDS=45
KILN_SHADOWBOX_FLEXTESA_START_TIMEOUT_SECONDS=180

# Append-only JSONL activity log.
# Local dev: leave as `logs/kiln-activity.log` (repo-relative).
# Hetzner systemd unit pins this to `/var/log/kiln/activity.log`.
KILN_ACTIVITY_LOG_PATH=logs/kiln-activity.log

# Native hosting paths (Hetzner). Leave blank in local dev.
# In production the systemd unit provides these:
#   KILN_PYTHON=/opt/platform/venvs/kiln/bin/python
#   KILN_EXPORT_ROOT=/var/lib/kiln/exports
#   KILN_REFERENCE_ROOT=/var/lib/kiln/reference
KILN_PYTHON=
KILN_EXPORT_ROOT=
KILN_REFERENCE_ROOT=

# Hard caps on the reference corpus downloaded by
# scripts/fetch-reference-mainnet-contracts.py. Protects the host disk.
KILN_REFERENCE_MAX_FILES=200
KILN_REFERENCE_MAX_BYTES=209715200

# Optional CORS allowlist (comma-separated)
# For kiln.wtfgameshow.app the frontend and API share origin so this
# can normally stay empty. Wildcards supported, e.g. https://*.netlify.app
CORS_ORIGINS=
